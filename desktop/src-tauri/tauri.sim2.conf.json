{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YiboVibe Desktop Sim 2",
  "version": "0.9.7",
  "identifier": "com.yibovibe.desktop.sim2",
  "build": {
    "beforeDevCommand": "run_vite.cmd --port 1421 --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "run_vite.cmd build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YiboVibe Sim 2",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
