{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YiboVibe Desktop",
  "version": "0.9.7",
  "identifier": "com.yibovibe.desktop",
  "build": {
    "beforeDevCommand": "run_vite.cmd",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "run_vite.cmd build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YiboVibe",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
