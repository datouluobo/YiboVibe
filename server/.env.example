# ==========================================
# YiboFlow 生产环境变量配置 (针对 NAS/Docker)
# 注意: 这份文件不应被提交入公网代码库
# 部署群晖、绿联等 NAS 时，只需修改以下的强密文字段
# ==========================================

# ================= 1. PostgreSQL 核心数据库设置 ================= 
POSTGRES_USER=yibo_admin
# 请务必在此处输入极其复杂的安全密码（切勿使用弱密码）
POSTGRES_PASSWORD=secret_postgres_password_change_me
POSTGRES_DB=yiboflow

# ================= 2. Redis 内存缓存层设置 ================= 
# 请勿留空，Redis密码对于防止勒索病毒极度重要
REDIS_PASSWORD=secret_redis_password_change_me

# ================= 3. YiboFlow 守护进程设置 ================= 
# 局域网暴露端口 (例如改成想映射的端口 9090 ，则可通过 NAS_IP:9090 防问)
PORT=8080
GIN_MODE=release
